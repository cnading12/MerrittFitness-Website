# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=xxx

# Resend
RESEND_API_KEY=re_xxx

# Google Calendar (service account)
GOOGLE_CLIENT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=xxx@group.calendar.google.com

# Vercel Cron (shared secret validated by /api/cron/* handlers)
CRON_SECRET=xxx

# Admin trigger endpoint (x-admin-secret header for /api/admin/*)
ADMIN_API_SECRET=xxx

# Ops distribution list for recurring billing emails.
#   - Monthly-billing roll-up is sent to both addresses in a single send
#     (one thread, both inboxes).
#   - Every client-facing recurring billing email (monthly billing invoice,
#     recurring setup confirmation) BCCs both addresses.
# If one is missing, the sender falls back to the one that is set and logs
# a warning. If both are missing, the roll-up is skipped and client-facing
# emails go out without BCC.
OPS_EMAIL_MANAGER=manager@merrittwellness.net
OPS_EMAIL_CLIENT_SERVICES=clientservices@merrittwellness.net
